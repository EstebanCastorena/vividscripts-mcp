{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "image_count": {
      "type": "integer",
      "minimum": 1
    },
    "rationale": {
      "type": "string"
    },
    "beats": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "index": {
            "type": "integer"
          },
          "text_portion": {
            "type": "string"
          },
          "word": {
            "type": "string"
          }
        },
        "required": [
          "index"
        ]
      }
    }
  },
  "required": [
    "image_count"
  ]
}
